<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mortgage Renewal Payment Shock Calculator</title>
  <style>
    * {
      box-sizing: border-box;
    }

    :root {
      --bg: #f4f7fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --blue: #2563eb;
      --blue-dark: #1d4ed8;
      --blue-soft: #eff6ff;
      --blue-border: #bfdbfe;
      --red-soft: #fef2f2;
      --red-border: #fecaca;
      --red-text: #b91c1c;
      --green-soft: #ecfdf5;
      --green-border: #bbf7d0;
      --green-text: #166534;
      --shadow: 0 14px 40px rgba(0, 0, 0, 0.08);
      --radius: 20px;
    }

    body {
      margin: 0;
      padding: 24px;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .page {
      max-width: 860px;
      margin: 0 auto;
    }

    .card {
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .hero {
      padding: 34px 30px 26px;
      background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
      border-bottom: 1px solid #e5e7eb;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 12px;
      padding: 8px 12px;
      border-radius: 999px;
      background: #eef2ff;
      color: #3730a3;
      font-size: 13px;
      font-weight: 700;
    }

    h1 {
      margin: 0 0 12px;
      font-size: 34px;
      line-height: 1.15;
      letter-spacing: -0.02em;
    }

    .subtext {
      margin: 0;
      font-size: 18px;
      line-height: 1.6;
      color: #4b5563;
      max-width: 760px;
    }

    .content {
      padding: 28px 30px 30px;
    }

    .intro-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 18px;
      margin-bottom: 24px;
    }

    .mini-card {
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      padding: 18px;
      background: #fff;
    }

    .mini-card h3 {
      margin: 0 0 12px;
      font-size: 18px;
    }

    .mini-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
      font-size: 15px;
    }

    .example-list {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .example-list li {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      padding: 8px 0;
      border-bottom: 1px solid #f1f5f9;
      font-size: 15px;
    }

    .example-list li:last-child {
      border-bottom: none;
    }

    .example-list strong {
      white-space: nowrap;
    }

    .trust {
      margin-top: 10px;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
    }

    .lead-gate {
      padding: 22px;
      border: 1px solid #dbeafe;
      background: #f8fbff;
      border-radius: 18px;
      margin-bottom: 26px;
    }

    .lead-gate h2 {
      margin: 0 0 8px;
      font-size: 24px;
      color: #1e3a8a;
    }

    .lead-gate p {
      margin: 0 0 18px;
      color: #4b5563;
      line-height: 1.6;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .field {
      display: flex;
      flex-direction: column;
    }

    .field.full {
      grid-column: 1 / -1;
    }

    .field label {
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 8px;
      color: #374151;
    }

    .field input {
      width: 100%;
      padding: 16px;
      font-size: 18px;
      border: 1px solid #d1d5db;
      border-radius: 12px;
      outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
      background: #fff;
    }

    .field input:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
    }

    .helper {
      margin-top: 6px;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
    }

    .btn-row {
      margin-top: 20px;
    }

    .btn {
      width: 100%;
      border: none;
      border-radius: 14px;
      background: var(--blue);
      color: #fff;
      padding: 17px 20px;
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s ease, transform 0.1s ease;
    }

    .btn:hover {
      background: var(--blue-dark);
    }

    .btn:active {
      transform: translateY(1px);
    }

    .message-error,
    .message-success {
      display: none;
      margin-top: 14px;
      padding: 12px 14px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 600;
      line-height: 1.5;
    }

    .message-error {
      background: var(--red-soft);
      border: 1px solid var(--red-border);
      color: var(--red-text);
    }

    .message-success {
      background: var(--green-soft);
      border: 1px solid var(--green-border);
      color: var(--green-text);
    }

    .calculator-section {
      display: none;
      margin-top: 8px;
    }

    .calculator-section h2 {
      margin: 0 0 8px;
      font-size: 28px;
    }

    .calculator-section .section-text {
      margin: 0 0 20px;
      color: var(--muted);
      line-height: 1.6;
    }

    .results {
      display: none;
      margin-top: 26px;
    }

    .shock-box {
      border-radius: 20px;
      padding: 24px;
      background: linear-gradient(180deg, #fff1f2 0%, #ffffff 100%);
      border: 1px solid #fecdd3;
      margin-bottom: 20px;
    }

    .shock-box .label {
      display: inline-block;
      margin-bottom: 12px;
      padding: 7px 11px;
      border-radius: 999px;
      background: #ffe4e6;
      color: #9f1239;
      font-size: 13px;
      font-weight: 700;
    }

    .shock-box h3 {
      margin: 0 0 10px;
      font-size: 22px;
    }

    .shock-amount {
      font-size: 48px;
      font-weight: 800;
      line-height: 1;
      color: #b91c1c;
      letter-spacing: -0.03em;
      margin: 10px 0 8px;
    }

    .shock-sub {
      font-size: 18px;
      color: #7f1d1d;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .shock-copy {
      margin: 0;
      color: #4b5563;
      line-height: 1.6;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 20px;
    }

    .summary-card {
      padding: 20px;
      border-radius: 18px;
      background: var(--blue-soft);
      border: 1px solid var(--blue-border);
    }

    .summary-card h4 {
      margin: 0 0 12px;
      font-size: 18px;
      color: #1e3a8a;
    }

    .row {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      padding: 10px 0;
      border-bottom: 1px solid #dbeafe;
    }

    .row:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .row-label {
      font-size: 15px;
      color: #374151;
      font-weight: 600;
    }

    .row-value {
      font-size: 16px;
      color: #111827;
      font-weight: 700;
      text-align: right;
    }

    .scenarios {
      border: 1px solid #e5e7eb;
      border-radius: 18px;
      padding: 22px;
      background: #fff;
      margin-bottom: 20px;
    }

    .scenarios h3 {
      margin: 0 0 8px;
      font-size: 22px;
    }

    .scenarios p {
      margin: 0 0 16px;
      color: var(--muted);
      line-height: 1.6;
    }

    .scenario-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .scenario-card {
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      padding: 18px;
      background: #fafafa;
    }

    .scenario-rate {
      font-size: 14px;
      font-weight: 700;
      color: #1d4ed8;
      margin-bottom: 8px;
    }

    .scenario-payment {
      font-size: 28px;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 8px;
      color: #111827;
      letter-spacing: -0.02em;
    }

    .scenario-diff {
      font-size: 14px;
      font-weight: 700;
      color: #b91c1c;
      margin-bottom: 8px;
    }

    .scenario-note {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
    }

    .action-box {
      padding: 22px;
      border-radius: 18px;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
    }

    .action-box h3 {
      margin: 0 0 10px;
      font-size: 22px;
    }

    .action-box p {
      margin: 0 0 16px;
      color: #4b5563;
      line-height: 1.7;
    }

    .cta-btn {
      display: inline-block;
      text-decoration: none;
      background: #111827;
      color: #fff;
      padding: 15px 20px;
      border-radius: 12px;
      font-weight: 700;
      font-size: 15px;
    }

    .timing-note {
      margin-top: 14px;
      font-size: 14px;
      color: #374151;
      line-height: 1.6;
    }

    .disclaimer {
      margin-top: 20px;
      padding: 14px 16px;
      border-radius: 12px;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
    }

    @media (max-width: 820px) {
      .intro-grid,
      .summary-grid,
      .scenario-grid,
      .grid {
        grid-template-columns: 1fr;
      }

      .field.full {
        grid-column: auto;
      }
    }

    @media (max-width: 640px) {
      body {
        padding: 14px;
      }

      .hero,
      .content {
        padding: 22px 20px;
      }

      h1 {
        font-size: 28px;
      }

      .subtext {
        font-size: 16px;
      }

      .shock-amount {
        font-size: 38px;
      }

      .row {
        flex-direction: column;
        gap: 6px;
      }

      .row-value {
        text-align: left;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="card">
      <div class="hero">
        <div class="eyebrow">Mortgage renewal tool for Canadian homeowners</div>
        <h1>See What Your Mortgage Payment Could Jump To At Renewal</h1>
        <p class="subtext">
          Most homeowners focus on rate alone. What usually matters more is what that new rate does
          to your monthly payment. Enter your details below and see the difference.
        </p>
      </div>

      <div class="content">
        <div class="intro-grid">
          <div class="mini-card">
            <h3>What this calculator shows</h3>
            <p>
              You will see your estimated current monthly payment, how that payment changes at
              renewal, and how much extra that could mean per month and per year.
            </p>
            <div class="trust">
              Many Canadian homeowners renewing in the next 6 to 18 months are surprised by how much
              their payment can change.
            </div>
          </div>

          <div class="mini-card">
            <h3>Quick example</h3>
            <ul class="example-list">
              <li><span>Mortgage balance</span><strong>$850,000</strong></li>
              <li><span>Current rate</span><strong>2.49%</strong></li>
              <li><span>Remaining amortization</span><strong>22 years</strong></li>
              <li><span>Payment at 4.00%</span><strong>Higher monthly cost</strong></li>
            </ul>
            <div class="trust">
              Enter your email to unlock the calculator and run your own numbers.
            </div>
          </div>
        </div>

        <div class="lead-gate">
          <h2>Unlock the calculator</h2>
          <p>
            Enter your name and email to access the calculator and see what your payment could look
            like at renewal.
          </p>

          <div class="grid">
            <div class="field">
              <label for="leadName">Name</label>
              <input type="text" id="leadName" placeholder="Your name" />
            </div>

            <div class="field">
              <label for="leadEmail">Email Address</label>
              <input type="email" id="leadEmail" placeholder="you@example.com" />
            </div>
          </div>

          <div class="btn-row">
            <button class="btn" id="unlockBtn">Access My Calculator</button>
          </div>

          <div class="message-error" id="leadError">
            Please enter a valid name and email address.
          </div>

          <div class="message-success" id="leadSuccess">
            Thanks. Your calculator is now unlocked below.
          </div>
        </div>

        <div class="calculator-section" id="calculatorSection">
          <h2>Mortgage Renewal Payment Shock Calculator</h2>
          <p class="section-text">
            Enter your mortgage details below. This tool uses standard monthly mortgage payment
            calculations and shows three sample renewal scenarios for comparison.
          </p>

          <div class="grid">
            <div class="field">
              <label for="balance">Mortgage Balance ($)</label>
              <input type="number" id="balance" placeholder="Example: 850000" min="0" step="0.01" />
            </div>

            <div class="field">
              <label for="currentRate">Current Interest Rate (%)</label>
              <input type="number" id="currentRate" placeholder="Example: 2.49" min="0" step="0.01" />
            </div>

            <div class="field full">
              <label for="amortization">Remaining Amortization (years)</label>
              <input type="number" id="amortization" placeholder="Example: 22" min="1" step="1" />
              <div class="helper">
                Results below compare your current payment with sample renewal rates of 4.00%,
                4.50%, and 5.00%.
              </div>
            </div>
          </div>

          <div class="btn-row">
            <button class="btn" id="calculateBtn">Show My Payment Change</button>
          </div>

          <div class="message-error" id="calcError">
            Please enter valid numbers in all calculator fields.
          </div>

          <div class="results" id="results">
            <div class="shock-box">
              <div class="label">Estimated payment shock</div>
              <h3>Your monthly payment could increase by</h3>
              <div class="shock-amount" id="shockAmount">$0</div>
              <div class="shock-sub" id="shockAnnual">About $0 more per year</div>
              <p class="shock-copy" id="shockCopy">
                Your summary will appear here after you run the calculation.
              </p>
            </div>

            <div class="summary-grid">
              <div class="summary-card">
                <h4>Current payment</h4>
                <div class="row">
                  <div class="row-label">Current monthly payment</div>
                  <div class="row-value" id="currentPayment">$0.00</div>
                </div>
              </div>

              <div class="summary-card">
                <h4>Base renewal scenario</h4>
                <div class="row">
                  <div class="row-label">Monthly payment at 4.00%</div>
                  <div class="row-value" id="renewal4Payment">$0.00</div>
                </div>
                <div class="row">
                  <div class="row-label">Annual increase at 4.00%</div>
                  <div class="row-value" id="annualIncrease">$0.00</div>
                </div>
              </div>
            </div>

            <div class="scenarios">
              <h3>Compare renewal scenarios</h3>
              <p>
                Rates move. Seeing more than one scenario gives you a better idea of how sensitive
                your payment is to change.
              </p>

              <div class="scenario-grid">
                <div class="scenario-card">
                  <div class="scenario-rate">Scenario 1 — 4.00%</div>
                  <div class="scenario-payment" id="scenario4Payment">$0</div>
                  <div class="scenario-diff" id="scenario4Diff">$0 / month increase</div>
                  <div class="scenario-note">A softer renewal scenario.</div>
                </div>

                <div class="scenario-card">
                  <div class="scenario-rate">Scenario 2 — 4.50%</div>
                  <div class="scenario-payment" id="scenario45Payment">$0</div>
                  <div class="scenario-diff" id="scenario45Diff">$0 / month increase</div>
                  <div class="scenario-note">A mid-range scenario for comparison.</div>
                </div>

                <div class="scenario-card">
                  <div class="scenario-rate">Scenario 3 — 5.00%</div>
                  <div class="scenario-payment" id="scenario5Payment">$0</div>
                  <div class="scenario-diff" id="scenario5Diff">$0 / month increase</div>
                  <div class="scenario-note">A higher pressure scenario.</div>
                </div>
              </div>
            </div>

            <div class="action-box">
              <h3>If this increase feels uncomfortable, there may be options</h3>
              <p>
                It may not just be a rate problem. Mortgage structure can sometimes reduce monthly
                pressure. A short strategy review can help you compare the best next step based on
                your payment, risk, and timeline.
              </p>

              <a
                href="https://calendly.com/jtmortgages/discovery-call-1"
                target="_blank"
                rel="noopener noreferrer"
                class="cta-btn"
              >
                Review My Mortgage Options
              </a>

              <div class="timing-note">
                If your mortgage renews in the next 6 to 18 months, you may have options before
                renewal that help reduce payment shock.
              </div>

              <div class="disclaimer">
                Disclaimer: This calculator provides estimates for general illustration only. It
                assumes standard monthly mortgage payments and uses sample renewal rates of 4.00%,
                4.50%, and 5.00%. Actual payment amounts may vary based on lender terms, payment
                frequency, mortgage type, compounding method, fees, and any changes made at renewal.
                This is not a rate quote, commitment, or financial advice.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbz3Oe4sg-TrmaZ28kacvh_xuDOPUAvDCB9O0c9furY4XkCB0uQYS_Q1lt6Y8CD97YKY/exec";

    const RATE_1 = 4.0;
    const RATE_2 = 4.5;
    const RATE_3 = 5.0;

    function formatCurrency(value) {
      return new Intl.NumberFormat("en-CA", {
        style: "currency",
        currency: "CAD",
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value);
    }

    function formatCurrencyRounded(value) {
      return new Intl.NumberFormat("en-CA", {
        style: "currency",
        currency: "CAD",
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      }).format(value);
    }

    function isValidEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    /*
      Standard mortgage payment formula:

      M = P * [ r(1+r)^n ] / [ (1+r)^n - 1 ]

      M = monthly payment
      P = mortgage balance
      r = monthly interest rate
      n = total number of monthly payments

      If interest rate is 0, payment = principal / months
    */
    function calculateMonthlyPayment(principal, annualRatePercent, years) {
      const monthlyRate = (annualRatePercent / 100) / 12;
      const totalPayments = years * 12;

      if (monthlyRate === 0) {
        return principal / totalPayments;
      }

      return principal * (
        (monthlyRate * Math.pow(1 + monthlyRate, totalPayments)) /
        (Math.pow(1 + monthlyRate, totalPayments) - 1)
      );
    }

    async function storeLead(name, email) {
      try {
        await fetch(SCRIPT_URL, {
          method: "POST",
          body: JSON.stringify({ name, email }),
          headers: {
            "Content-Type": "text/plain;charset=utf-8"
          },
          mode: "no-cors"
        });
        return true;
      } catch (error) {
        console.error("Lead submission failed:", error);
        return false;
      }
    }

    function setText(id, value) {
      document.getElementById(id).textContent = value;
    }

    function buildShockCopy(monthlyIncrease) {
      if (monthlyIncrease <= 0) {
        return "Based on these numbers, your payment does not increase in the 4.00% scenario.";
      }

      if (monthlyIncrease < 300) {
        return "This is a manageable increase for some households, but it is still worth planning for ahead of renewal.";
      }

      if (monthlyIncrease < 700) {
        return "This is the kind of change many homeowners feel in monthly cash flow. Planning early can make a difference.";
      }

      return "This is a meaningful jump in monthly cost. A strategy review may help reduce the pressure before renewal.";
    }

    document.getElementById("unlockBtn").addEventListener("click", async function () {
      const name = document.getElementById("leadName").value.trim();
      const email = document.getElementById("leadEmail").value.trim();
      const leadError = document.getElementById("leadError");
      const leadSuccess = document.getElementById("leadSuccess");
      const calculatorSection = document.getElementById("calculatorSection");

      leadError.style.display = "none";
      leadSuccess.style.display = "none";

      if (!name || !isValidEmail(email)) {
        leadError.style.display = "block";
        return;
      }

      await storeLead(name, email);

      leadSuccess.style.display = "block";
      calculatorSection.style.display = "block";
      calculatorSection.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    document.getElementById("calculateBtn").addEventListener("click", function () {
      const balance = parseFloat(document.getElementById("balance").value);
      const currentRate = parseFloat(document.getElementById("currentRate").value);
      const amortization = parseFloat(document.getElementById("amortization").value);

      const calcError = document.getElementById("calcError");
      const results = document.getElementById("results");

      calcError.style.display = "none";

      if (
        isNaN(balance) || balance <= 0 ||
        isNaN(currentRate) || currentRate < 0 ||
        isNaN(amortization) || amortization <= 0
      ) {
        calcError.style.display = "block";
        results.style.display = "none";
        return;
      }

      const currentPayment = calculateMonthlyPayment(balance, currentRate, amortization);

      const payment4 = calculateMonthlyPayment(balance, RATE_1, amortization);
      const payment45 = calculateMonthlyPayment(balance, RATE_2, amortization);
      const payment5 = calculateMonthlyPayment(balance, RATE_3, amortization);

      const increase4 = payment4 - currentPayment;
      const increase45 = payment45 - currentPayment;
      const increase5 = payment5 - currentPayment;

      const annualIncrease4 = increase4 * 12;

      setText("shockAmount", formatCurrencyRounded(increase4) + " / month");
      setText("shockAnnual", "About " + formatCurrencyRounded(annualIncrease4) + " more per year");
      setText("shockCopy", buildShockCopy(increase4));

      setText("currentPayment", formatCurrency(currentPayment));
      setText("renewal4Payment", formatCurrency(payment4));
      setText("annualIncrease", formatCurrency(annualIncrease4));

      setText("scenario4Payment", formatCurrencyRounded(payment4));
      setText("scenario45Payment", formatCurrencyRounded(payment45));
      setText("scenario5Payment", formatCurrencyRounded(payment5));

      setText("scenario4Diff", formatCurrencyRounded(increase4) + " / month increase");
      setText("scenario45Diff", formatCurrencyRounded(increase45) + " / month increase");
      setText("scenario5Diff", formatCurrencyRounded(increase5) + " / month increase");

      results.style.display = "block";
      results.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  </script>
</body>
</html>
